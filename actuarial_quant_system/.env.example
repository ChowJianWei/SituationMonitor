# ---- infrastructure ----
REDIS_URL="redis://localhost:6379/0"
POSTGRES_DSN="postgresql://localhost:5432/actuarial"

# ---- api server ----
API_HOST="127.0.0.1"
API_PORT="8200"
CORS_ORIGIN="http://localhost:3000"

# ---- venue / execution ----
# Mint these keys with READ (and at most TRADE) scope. NEVER enable WITHDRAW.
BROKER_BASE_URL="https://sandbox.exchange.local"
BROKER_API_KEY=""
BROKER_API_SECRET=""

# Safety latch. Leave TRUE until a validated paper track record exists.
PAPER_TRADING_ONLY="true"

# ---- Tradier (equity options) ----
# EXECUTION_MODE: "paper" (internal simulator) or "tradier_sandbox".
EXECUTION_MODE="paper"
TRADIER_ENV="sandbox"            # sandbox = paper money, real API
TRADIER_ACCESS_TOKEN=""          # from dash.tradier.com -> API Access (sandbox)
TRADIER_ACCOUNT_ID=""            # your sandbox account id (starts with VA...)

# Autonomous paper underwriting cycle.
CYCLE_INTERVAL_SECONDS="60"
SEED_EQUITY_USD="180000"

# ---- market data ----
FRED_SERIES="DGS3MO"
FRED_API_KEY=""
